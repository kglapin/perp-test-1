---
const reviews = [
  {
    name: 'Marek Kowalski',
    role: 'Właściciel domu jednorodzinnego',
    rating: 5,
    text: 'BudMaster zrealizował budowę naszego domu w terminie i bez żadnych niespodzianek budżetowych. Polecam z czystym sumieniem!',
    city: 'Kraków',
  },
  {
    name: 'Anna Wiśniewska',
    role: 'Właścicielka apartamentu',
    rating: 5,
    text: 'Remont mieszkania przebiegł sprawnie i profesjonalnie. Ekipa schludna, terminowa i naprawdę wie co robi. Efekt przerósł oczekiwania.',
    city: 'Warszawa',
  },
  {
    name: 'Tomasz Nowak',
    role: 'Prezes firmy deweloperskiej',
    rating: 5,
    text: 'Współpracujemy z BudMaster od 3 lat przy realizacji osiedli. Niezawodny partner — jakość, terminowość i komunikacja na najwyższym poziomie.',
    city: 'Wrocław',
  },
];
---

<section id="opinie" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-primary-600 font-semibold text-sm uppercase tracking-widest">Opinie klientów</span>
      <h2 class="font-heading text-4xl md:text-5xl font-black text-gray-900 mt-3 mb-4">
        Co mówią nasi Klienci
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((r) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {Array.from({length: r.rating}).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 leading-relaxed mb-6 italic">"{r.text}"</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center font-bold text-primary-600">
              {r.name[0]}
            </div>
            <div>
              <div class="font-semibold text-gray-900">{r.name}</div>
              <div class="text-gray-400 text-sm">{r.role} · {r.city}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
