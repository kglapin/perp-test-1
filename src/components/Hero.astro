---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-dark-900">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-gray-900 to-primary-900 opacity-90"></div>
  
  <!-- Grid pattern -->
  <div class="absolute inset-0" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-primary-600/20 border border-primary-600/30 text-primary-400 px-4 py-2 rounded-full text-sm font-medium mb-8">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
      Ponad 15 lat doświadczenia na rynku
    </div>

    <h1 class="font-heading text-5xl md:text-7xl font-black text-white mb-6 leading-tight">
      Budujemy Twoje<br/>
      <span class="text-primary-500">Marzenia</span><br/>
      z Precyzją
    </h1>

    <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed">
      Kompleksowe usługi budowlane — od fundamentów po wykończenie. 
      Realizujemy projekty na czas, w budżecie i z najwyższą jakością.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#kontakt" class="bg-primary-600 hover:bg-primary-500 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all transform hover:scale-105 shadow-lg shadow-primary-600/25">
        Bezpłatna wycena →
      </a>
      <a href="#realizacje" class="border border-white/20 hover:border-white/40 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all hover:bg-white/5">
        Zobacz realizacje
      </a>
    </div>

    <!-- Stats -->
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8">
      {[
        { value: '500+', label: 'Zrealizowanych projektów' },
        { value: '15+', label: 'Lat doświadczenia' },
        { value: '98%', label: 'Zadowolonych klientów' },
        { value: '50+', label: 'Ekspertów w zespole' },
      ].map(stat => (
        <div class="text-center">
          <div class="font-heading text-4xl font-black text-primary-500">{stat.value}</div>
          <div class="text-gray-400 text-sm mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
