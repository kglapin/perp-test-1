---
---
<section id="kontakt" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Left - Info -->
      <div>
        <span class="text-primary-600 font-semibold text-sm uppercase tracking-widest">Kontakt</span>
        <h2 class="font-heading text-4xl md:text-5xl font-black text-gray-900 mt-3 mb-6">
          Porozmawiajmy o<br/><span class="text-primary-600">Twoim projekcie</span>
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed mb-10">
          Wypełnij formularz lub zadzwoń do nas bezpośrednio. Bezpłatna wycena w ciągu 48 godzin.
        </p>

        <div class="space-y-6">
          {[
            { icon: '📍', label: 'Adres', value: 'ul. Budowlana 12, 00-001 Warszawa' },
            { icon: '📞', label: 'Telefon', value: '+48 123 456 789' },
            { icon: '✉️', label: 'Email', value: 'biuro@budmaster.pl' },
            { icon: '🕒', label: 'Godziny', value: 'Pon–Pt: 8:00–17:00' },
          ].map(item => (
            <div class="flex gap-4 items-start">
              <span class="text-2xl">{item.icon}</span>
              <div>
                <div class="text-sm text-gray-400 font-medium">{item.label}</div>
                <div class="text-gray-800 font-medium">{item.value}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right - Form -->
      <div class="bg-gray-50 rounded-3xl p-8">
        <form class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Imię i nazwisko *</label>
              <input type="text" placeholder="Jan Kowalski" class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Telefon *</label>
              <input type="tel" placeholder="+48 123 456 789" class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
            <input type="email" placeholder="jan@email.pl" class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Rodzaj usługi</label>
            <select class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
              <option>Wybierz usługę</option>
              <option>Budowa domu</option>
              <option>Remont mieszkania</option>
              <option>Wykończenie wnętrz</option>
              <option>Instalacje</option>
              <option>Inne</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Opis projektu</label>
            <textarea rows="4" placeholder="Opisz krótko czego potrzebujesz..." class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white py-4 rounded-xl font-bold text-lg transition-colors shadow-lg shadow-primary-600/25">
            Wyślij zapytanie →
          </button>
          <p class="text-xs text-gray-400 text-center">Odpowiadamy w ciągu 48 godzin. Wycena jest bezpłatna.</p>
        </form>
      </div>
    </div>
  </div>
</section>
